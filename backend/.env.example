# Copy to `.env` and adjust per environment (never commit secrets).

# Flask sessions / signing — use a strong random value in staging/production
SECRET_KEY=dev-change-me

# JWT signing (defaults to SECRET_KEY if unset). Use ≥32-byte secret for HS256 in production.
# JWT_SECRET_KEY=
# JWT_ACCESS_TOKEN_SECONDS=3600

# Postgres (host port matches docker-compose.yml mapped port 5434 → container 5432)
DATABASE_URL=postgresql+psycopg://app:app@localhost:5434/app

# Redis (host port matches docker-compose.yml mapped port 6381 → container 6379)
REDIS_URL=redis://localhost:6381/0

# OpenAPI + Swagger UI: served under OPENAPI_URL_PREFIX (see config.py).
# URLs: OPENAPI_JSON = {prefix}/{OPENAPI_JSON_PATH}, UI = {prefix}/{OPENAPI_SWAGGER_UI_PATH}

# CORS origins for browser clients (comma-separated). Matches Vite dev server by default.
# CORS_ORIGINS=http://127.0.0.1:5173,http://localhost:5173
